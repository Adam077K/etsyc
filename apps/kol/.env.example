# KOL — environment template. Copy to `.env.local` (gitignored) and fill the values.
# Get all values from the Supabase dashboard: https://supabase.com/dashboard/project/olwtcjzmohdhawdzlzqs
# ── which are secret ──────────────────────────────────────────────────────────
#   NEXT_PUBLIC_*  → shipped to the browser (safe to expose; anon key is RLS-guarded)
#   SUPABASE_SERVICE_ROLE_KEY / ACCESS_TOKEN / DB_PASSWORD → SERVER-ONLY SECRETS.
#     Never prefix these with NEXT_PUBLIC_. Never commit .env.local. Never paste them in chat.

# ── App runtime (P1 auth, P2 profile, all DB reads/writes) ─────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://olwtcjzmohdhawdzlzqs.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=            # "anon / public" key
SUPABASE_SERVICE_ROLE_KEY=                # "service_role" key — SERVER ONLY, bypasses RLS

# ── Migration apply / CLI (database-engineer only; not needed by the app) ──────
SUPABASE_PROJECT_REF=olwtcjzmohdhawdzlzqs
SUPABASE_ACCESS_TOKEN=                    # Dashboard → Account → Access Tokens (for `supabase link`/`db push`)
SUPABASE_DB_PASSWORD=                     # Dashboard → Project Settings → Database → the DB password
# Optional direct connection (psql / scripts): Dashboard → Settings → Database → Connection string (URI)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.olwtcjzmohdhawdzlzqs.supabase.co:5432/postgres

# ── Later waves (leave blank until their wave) ─────────────────────────────────
# STRIPE_SECRET_KEY=                       # Wave 3 (B7 checkout, TEST-MODE)
# STRIPE_PUBLISHABLE_KEY=
# ANTHROPIC_API_KEY=                       # Wave 2/4 (P7 tagging, S2 interview, S3 draft, P9 critic)
