# KOL — Supabase (staging project_ref: olwtcjzmohdhawdzlzqs)
# Copy to .env.local and fill in from the Supabase dashboard (Settings → API).
# NEVER commit real values. .env.local is gitignored.

# Public — safe to expose to the browser (anon key is RLS-scoped; RLS is the ONLY boundary).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-ONLY — bypasses RLS entirely. Used exclusively by the service-role client
# (src/lib/supabase/admin.ts, guarded by `server-only`). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
